# Hugging Face Inference API
# Token from https://huggingface.co/settings/tokens (read scope is enough for inference)
HF_API_TOKEN=
# Model repo id on the Hugging Face Hub. Defaults to a public DistilBERT
# sentiment model so the endpoint is runnable out of the box.
#
# Real fine-tuned checkpoint, starting point for testing inference against
# the NLP model: https://huggingface.co/YaphetL/gpt2-therapy-generator/tree/main
# It's a text-generation (GPT-2/GPT-Neo) checkpoint, not text-classification,
# so pointing HF_MODEL_ID at it as-is will not work with this file's response
# parsing (which expects classifier-shaped {label, score} output) -- that
# parsing needs updating first if/when this becomes the active model.
HF_MODEL_ID=distilbert-base-uncased-finetuned-sst-2-english

# Optional: also publish each classified turn to the Kafka pipeline in
# ../pipeline/kafka_producer.py. Leave KAFKA_ENABLED=false to run the API
# standalone without a Kafka broker.
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Comma-separated list of origins allowed to call this API (the Vite dev
# server default is included below).
CORS_ORIGINS=http://localhost:5173
